40RB02_G2_A\", \"14_MB140RB02_G1_B\", \"14_MB140RB02_G2_B\", \"14_MB140RB02_G1_C\", \"14_MB140RB02_G2_C\",\n    \"15_MB140RB03_G1_A\", \"15_MB140RB03_G2_A\", \"15_MB140RB03_G1_B\", \"15_MB140RB03_G2_B\", \"15_MB140RB03_G1_C\", \"15_MB140RB03_G2_C\",\n    \"16_MB140RB04_G1_A\", \"16_MB140RB04_G2_A\", \"16_MB140RB04_G1_B\", \"16_MB140RB04_G2_B\", \"16_MB140RB04_G1_C\", \"16_MB140RB04_G2_C\"\n];\n\nlet records = [];\n\nfor (let key of robotTipChangeArrays) {\n\n\n    let parts = key.split(\"_\");\n   \n    {\n       \n        let value = input[key];\n  \n        if (value <= 0) {\n            continue;\n        }\n\n        if (!(key in lastActualData) || lastActualData[key] !== value) {\n\n        //11_MB130RB01_G1_A\n        let robotId = parts[0];\n        let robotName = parts[1];\n        let gunName = parts[2];\n        let shift = parts[3];\n        \n\n        let gunId = 1;\n\n        if(gunName == \"G2\") {\n            gunId = 2;\n        }\n        \n        // \"16_MB140RB04_G1_BiwNo\"\n        let _Value = input[robotId + \"_\" + robotName + \"_\" + gunName + \"_\" + shift];\n        \n\n        // if (!(key in lastActualData) || lastActualData[key] !== value) {\n            \n          \n            lastActualData[key] = value;\n\n\n          \n            records.push({\n                RobotID: parseInt(robotId),\n                GunID: parseInt(gunId),\n                Shift: shift,\n                Value: _Value,\n\n                Timstamp: toSqlDate(new Date())\n});\n\n        }\n    }\n}\n////\n//node.warn(JSON.stringify(records, null, 2));\n\n// ✅ send ONE JSON instead of multiple queries\nif (records.length > 0) {\n    node.warn(\"inside dump\");\n    flow.set(\"LastRobotTipChange\", lastActualData);\n    msg.procedure = \"SP_Insert_Rbt_TipChangeCount\";\n    msg.payload = JSON.stringify(records);\n\n    return msg;\n}\n\nflow.set(\"LastRobotTipChange\", lastActualData);\nreturn records;\n\n\nfunction toSqlDate(date) {\n\n    let d = new Date(date);\n\n    let yyyy = d.getFullYear();\n    let MM = String(d.getMonth() + 1).padStart(2, '0');\n    let dd = String(d.getDate()).padStart(2, '0');\n\n    let hh = String(d.getHours()).padStart(2, '0');\n    let mm = String(d.getMinutes()).padStart(2, '0');\n    let ss = String(d.getSeconds()).padStart(2, '0');\n\n    return `${yyyy}-${MM}-${dd} ${hh}:${mm}:${ss}`;\n}",
