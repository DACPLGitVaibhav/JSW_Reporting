    {
        "id": "7e7d44dbbe7c2cf4",
        "type": "function",
        "z": "fca1b16516868aa0",
        "name": "Robot_SpotCount_Function",
        "func": "\n//With JSON\nlet lastActualData = flow.get(\"LastRobotBiw\") || {};\n\nlet input = msg.payload;\n//\nlet robotBiwArrays = [\n    \"1_MB110RB01_G1_BiwNo\",\n    \"2_MB110RB02_G1_BiwNo\",\n    \"3_MB110RB03_G1_BiwNo\",\n    \"4_MB110RB04_G1_BiwNo\",\n\n    \"5_MB120RB01_G1_BiwNo\",\n    \"6_MB120RB02_G1_BiwNo\",\n    \"7_MB120RB03_G1_BiwNo\",\n    \"8_MB120RB04_G1_BiwNo\",\n    \"9_MB120RB05_G1_BiwNo\",\n    \"10_MB120RB06_G1_BiwNo\",\n\n    \"11_MB130RB01_G1_BiwNo\",\n    \"12_MB130RB02_G1_BiwNo\",\n\n    \"13_MB140RB01_G1_BiwNo\",\n    \"14_MB140RB02_G1_BiwNo\",\n    \"15_MB140RB03_G1_BiwNo\",\n    \"16_MB140RB04_G1_BiwNo\"\n];\n\nlet records = [];\n\nfor (let key of robotBiwArrays) {\n\n\n    let parts = key.split(\"_\");\n   \n    if (parts[3] == \"BiwNo\") {\n       \n        let value = input[key];\n  \n        if (value <= 0) {\n            continue;\n        }\n        \n        if (!(key in lastActualData) || lastActualData[key] !== value) {\n\n        let robotId = parts[0];\n        \n        let robotName = parts[1];\n\n        let gunId = 1; //since only one gun key is available\n        \n        let _BiwNo = input[robotId + \"_\" + robotName + \"_\" + \"G1\" + \"_\" + \"BiwNo\"];\n        let _Variant = input[robotId + \"_\" + robotName + \"_\" + \"G1\" + \"_\" + \"Variant\"];\n\n            let _SubVariant = input[robotId + \"_\" + robotName + \"_\" + \"G1\" + \"_\" + \"Sub-Variant\"];\n\n            let _SpotTarget = input[robotId + \"_\" + robotName + \"_\" + \"G1\" + \"_\" + \"SpotTarget\"];\n      \n            let _SpotActual = input[robotId + \"_\" + robotName + \"_\" + \"G1\" + \"_\" + \"SpotActual\"];\n\n        //same goes to gun 2\n        //#region\n            //let _BiwNoG2 = input[robotId + \"_\" + robotName + \"_\" + \"G2\" + \"_\" + \"BiwNo\"];\n            //let _VariantG2 = input[robotId + \"_\" + robotName + \"_\" + \"G2\" + \"_\" + \"Variant\"];\n\n            //let _SubVariantG2 = input[robotId + \"_\" + robotName + \"_\" + \"G2\" + \"_\" + \"Sub-Variant\"];\n\n            let _SpotTargetG2 = input[robotId + \"_\" + robotName + \"_\" + \"G2\" + \"_\" + \"SpotTarget\"];\n\n            let _SpotActualG2 = input[robotId + \"_\" + robotName + \"_\" + \"G2\" + \"_\" + \"SpotActual\"];\n        //#endregion \n\n\n        // if (!(key in lastActualData) || lastActualData[key] !== value) {\n            \n           \n            lastActualData[key] = value;\n\n            records.push({\n                RobotID: parseInt(robotId),\n                GunID: parseInt(gunId),\n                Biwno: _BiwNo,\n                Varraint: _Variant,\n                SubVarraint: _SubVariant,\n\n                Target: _SpotTarget,\n                Actual: _SpotActual,\n\n                Timestamp: toSqlDate(new Date())\n},\n{\n    RobotID: parseInt(robotId),\n    GunID: 2,\n    Biwno: _BiwNo,\n    Varraint: _Variant,\n    SubVarraint: _SubVariant,\n\n    Target: _SpotTargetG2,\n    Actual: _SpotActualG2,\n\n    Timestamp: toSqlDate(new Date())\n});\n\n        }\n    }\n}\n////\n//node.warn(JSON.stringify(records, null, 2));\n\n// ✅ send ONE JSON instead of multiple queries\nif (records.length > 0) {\n    node.warn(\"inside dump\");\n    flow.set(\"LastRobotBiw\", lastActualData);\n    msg.procedure = \"SP_Insert_Rbt_SpotCount\";\n    msg.payload = JSON.stringify(records);\n\n    return msg;\n}\n\nflow.set(\"LastRobotBiw\", lastActualData);\nreturn records;\n\n\nfunction toSqlDate(date) {\n\n    let d = new Date(date);\n\n    let yyyy = d.getFullYear();\n    let MM = String(d.getMonth() + 1).padStart(2, '0');\n    let dd = String(d.getDate()).padStart(2, '0');\n\n    let hh = String(d.getHours()).padStart(2, '0');\n    let mm = String(d.getMinutes()).padStart(2, '0');\n    let ss = String(d.getSeconds()).padStart(2, '0');\n\n    return `${yyyy}-${MM}-${dd} ${hh}:${mm}:${ss}`;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 300,
        "wires": [
